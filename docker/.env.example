# ==============================================================================
# Environment Configuration Template for WhatsApp Appointment Notifier
# ==============================================================================
# COPY THIS FILE TO `docker/.env` AND CUSTOMIZE THE VALUES.
# DO NOT COMMIT THE ACTUAL `.env` FILE CONTAINING SECRETS TO THE REPOSITORY!
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL Database Settings
# ------------------------------------------------------------------------------
POSTGRES_USER=notifier
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=notifier
POSTGRES_DB_N8N=n8n
POSTGRES_DB_EVOLUTION=evolution
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# n8n Orchestrator Settings
# ------------------------------------------------------------------------------
# N8N_HOST is used only by scripts/start.sh for display purposes.
# The container always binds to 0.0.0.0 (hardcoded in docker-compose.yml).
# Use WEBHOOK_URL below to set the public-facing URL n8n uses for webhooks.
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Europe/Madrid
TZ=Europe/Madrid
N8N_ENCRYPTION_KEY=change-me-random-n8n-encryption-key-12345

# ------------------------------------------------------------------------------
# Evolution API Settings
# ------------------------------------------------------------------------------
EVOLUTION_API_PORT=8080
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=change-me-evolution-api-key
EVOLUTION_INSTANCE_NAME=clinic-notifier

# ------------------------------------------------------------------------------
# Bot and Notification Settings
# ------------------------------------------------------------------------------
BOT_ENABLED=false
BOT_LANGUAGE=es
DEFAULT_COUNTRY_CODE=+34

# ------------------------------------------------------------------------------
# Bot Memory and Retention Settings
# ------------------------------------------------------------------------------
MAX_CONTEXT_MESSAGES=10
ENABLE_CROSS_APPOINTMENT_MEMORY=true
PROFILE_MEMORY_RETENTION_DAYS=90
SESSION_EXPIRY_HOURS=72
